{
  "expo": {
    "name": "Dialuna",
    "slug": "dialuna",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/dialuna/app-icon.png",
    "scheme": "dialuna",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/dialuna/app-icon.png",
      "bundleIdentifier": "com.cuongphan2.dialuna"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#F4E7DD",
        "foregroundImage": "./assets/dialuna/app-icon.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.cuongphan2.dialuna"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/dialuna/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FAF1EA",
          "image": "./assets/dialuna/splash-screen.png",
          "imageWidth": 414,
          "resizeMode": "cover",
          "enableFullScreenImage_legacy": true
        }
      ],
      "expo-localization"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
